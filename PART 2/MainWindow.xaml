<Window x:Class="CyberSecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberShield — Cybersecurity Awareness Bot"
        Height="800" Width="1150"
        MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        FontFamily="Consolas">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- LEFT SIDEBAR                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#0F1628"
                BorderBrush="#1A3A5C" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Title -->
                <Border DockPanel.Dock="Top" Padding="12,14,12,12"
                        BorderBrush="#1A3A5C" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="CYBERSHIELD"
                                   Foreground="#00D4FF" FontSize="18"
                                   FontWeight="Bold" TextAlignment="Center"/>
                        <TextBlock Text="Cybersecurity Awareness Bot"
                                   Foreground="#8BA8C4" FontSize="10"
                                   TextAlignment="Center" Margin="0,2,0,0"/>
                        <Rectangle Height="1" Margin="0,10,0,0">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#00D4FF"     Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                </Border>

                <!-- User Status -->
                <Border DockPanel.Dock="Top" Margin="10,10,10,0"
                        Padding="10,8" BorderBrush="#1A3A5C"
                        BorderThickness="1" CornerRadius="6"
                        Background="#141D35">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="7" Height="7" Fill="#00FF88"
                                     Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="SYSTEM ONLINE" Foreground="#00FF88"
                                       FontSize="10" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="UserNameLabel"   Text="Agent: Anonymous" Foreground="#8BA8C4" FontSize="11" Margin="0,2"/>
                        <TextBlock x:Name="SentimentLabel"  Text="Mood: Neutral"    Foreground="#8BA8C4" FontSize="11" Margin="0,2"/>
                        <TextBlock x:Name="TopicLabel"      Text="Focus: None"      Foreground="#8BA8C4" FontSize="11" Margin="0,2"/>
                        <TextBlock x:Name="FavTopicLabel"   Text="Interest: —"      Foreground="#8BA8C4" FontSize="11" Margin="0,2"/>
                    </StackPanel>
                </Border>

                <!-- Quick Topic Chips -->
                <StackPanel DockPanel.Dock="Top" Margin="10,12,10,0">
                    <TextBlock Text="QUICK TOPICS" Foreground="#8BA8C4"
                               FontSize="10" FontWeight="Bold" Margin="2,0,0,6"/>
                    <WrapPanel>
                        <Button Content="Passwords" Tag="password tips" Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="Phishing"  Tag="phishing tips" Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="Scams"     Tag="scam warning"  Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="Privacy"   Tag="privacy tips"  Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="Malware"   Tag="malware tips"  Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="Browsing"  Tag="safe browsing" Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="Wi-Fi"     Tag="wifi security" Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="2FA"       Tag="2fa tips"      Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                        <Button Content="Breaches"  Tag="data breach"   Click="TopicChip_Click" Margin="2" Padding="6,3" FontSize="10" Background="#0F1628" Foreground="#8BA8C4" BorderBrush="#1A3A5C" Cursor="Hand"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Memory Panel -->
                <Border DockPanel.Dock="Top" Margin="10,12,10,0"
                        Padding="10,8" BorderBrush="#1A3A5C"
                        BorderThickness="1" CornerRadius="6"
                        Background="#0A0E1A">
                    <StackPanel>
                        <TextBlock Text="MEMORY" Foreground="#7B5EA7"
                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock x:Name="MemoryTopicsLabel"
                                   Text="No topics discussed yet."
                                   Foreground="#8BA8C4" FontSize="10"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Clear Chat Button -->
                <Button DockPanel.Dock="Bottom" Content="Clear Chat"
                        Margin="10,0,10,10" Padding="10,7"
                        Background="Transparent" Foreground="#8BA8C4"
                        BorderBrush="#1A3A5C" FontSize="12"
                        Cursor="Hand" Click="ClearChat_Click"/>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- RIGHT MAIN AREA                                                 -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="1">

            <!-- Top Bar -->
            <Border DockPanel.Dock="Top" Padding="16,10"
                    Background="#0F1628"
                    BorderBrush="#1A3A5C" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                    <GradientStop Color="#0055AA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="S" FontSize="16" FontWeight="Bold"
                                       Foreground="#0A0E1A"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CyberShield Assistant"
                                       Foreground="#E8F4F8" FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="StatusBarText"
                                       Text="Ready to help you stay secure online"
                                       Foreground="#8BA8C4" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border x:Name="SentimentBadge" Padding="8,4"
                                CornerRadius="10" Margin="0,0,10,0"
                                Background="#141D35" BorderBrush="#1A3A5C" BorderThickness="1">
                            <TextBlock x:Name="SentimentBadgeText"
                                       Text="Neutral" Foreground="#8BA8C4" FontSize="11"/>
                        </Border>
                        <TextBlock x:Name="ClockLabel" Foreground="#8BA8C4"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Tab Bar -->
            <Border DockPanel.Dock="Top" Background="#0A0E1A"
                    BorderBrush="#1A3A5C" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="TabChat"     Content="Chat"         Click="Tab_Click" Tag="Chat"
                            Padding="22,10" Background="#141D35" Foreground="#00D4FF"
                            BorderThickness="0,0,0,2" BorderBrush="#00D4FF"
                            FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="TabTasks"    Content="Tasks"        Click="Tab_Click" Tag="Tasks"
                            Padding="22,10" Background="Transparent" Foreground="#8BA8C4"
                            BorderThickness="0" FontSize="12" Cursor="Hand"/>
                    <Button x:Name="TabQuiz"     Content="Quiz"         Click="Tab_Click" Tag="Quiz"
                            Padding="22,10" Background="Transparent" Foreground="#8BA8C4"
                            BorderThickness="0" FontSize="12" Cursor="Hand"/>
                    <Button x:Name="TabActivity" Content="Activity Log" Click="Tab_Click" Tag="Activity"
                            Padding="22,10" Background="Transparent" Foreground="#8BA8C4"
                            BorderThickness="0" FontSize="12" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- CHAT PANEL                                                   -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <DockPanel x:Name="PanelChat">

                <!-- Input Bar -->
                <Border DockPanel.Dock="Bottom" Padding="14,10"
                        Background="#0F1628"
                        BorderBrush="#1A3A5C" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InputBox" Grid.Column="0"
                                 Background="#141D35" Foreground="#E8F4F8"
                                 CaretBrush="#00D4FF" BorderBrush="#1A3A5C"
                                 FontSize="13" Padding="10,8"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"
                                 KeyDown="InputBox_KeyDown"
                                 TextChanged="InputBox_TextChanged"/>
                        <TextBlock x:Name="PlaceholderText"
                                   Text="Ask me about cybersecurity..."
                                   Foreground="#3A5A7A" FontSize="13"
                                   Padding="12,8" VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <Button Grid.Column="1" Content="SEND"
                                Padding="18,8" FontWeight="Bold"
                                FontSize="13" Foreground="#0A0E1A"
                                BorderThickness="0" Cursor="Hand"
                                Click="SendButton_Click">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                    <GradientStop Color="#0088AA" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,10">
                    <StackPanel x:Name="ChatPanel"/>
                </ScrollViewer>
            </DockPanel>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- TASKS PANEL                                                  -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <Grid x:Name="PanelTasks" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Add Task Form -->
                <Border Grid.Row="0" Background="#0F1628"
                        BorderBrush="#1A3A5C" BorderThickness="0,0,0,1"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="Add New Task" Foreground="#E8F4F8"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,0">
                                <TextBlock Text="Title" Foreground="#8BA8C4" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="TaskTitleInput"
                                         Background="#141D35" Foreground="#E8F4F8"
                                         BorderBrush="#1A3A5C" Padding="8,6" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,10,0">
                                <TextBlock Text="Reminder Date (optional)" Foreground="#8BA8C4" FontSize="11" Margin="0,0,0,4"/>
                                <DatePicker x:Name="TaskReminderPicker"
                                            Background="#141D35" Foreground="#E8F4F8"
                                            BorderBrush="#1A3A5C" FontSize="12"/>
                            </StackPanel>

                            <Button Grid.Column="2" Grid.Row="0"
                                    Content="Add Task" Click="AddTask_Click"
                                    VerticalAlignment="Bottom"
                                    Padding="16,7" FontSize="12"
                                    Foreground="#0A0E1A" BorderThickness="0" Cursor="Hand">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00D4FF" Offset="0"/>
                                        <GradientStop Color="#0088AA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,10,0,0">
                                <TextBlock Text="Description (optional)" Foreground="#8BA8C4" FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="TaskDescInput"
                                         Background="#141D35" Foreground="#E8F4F8"
                                         BorderBrush="#1A3A5C" Padding="8,6" FontSize="12"
                                         TextWrapping="Wrap" Height="50"
                                         AcceptsReturn="True"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Task List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,14">
                    <StackPanel>
                        <TextBlock Text="Your Tasks" Foreground="#8BA8C4"
                                   FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListView x:Name="TaskListView"
          Background="Transparent"
          BorderThickness="0"
          Foreground="#E8F4F8"
          FontSize="12"
          SelectionMode="Single">
                            <ListView.Resources>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#E8F4F8"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#1A3A5C"/>
                                    <Setter Property="Padding" Value="4,6,4,6"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1A3A5C"/>
                                            <Setter Property="Foreground" Value="#E8F4F8"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#0F2A45"/>
                                            <Setter Property="Foreground" Value="#00D4FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Background" Value="#0F1628"/>
                                    <Setter Property="Foreground" Value="#8BA8C4"/>
                                    <Setter Property="BorderBrush" Value="#1A3A5C"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="4,6,4,6"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </ListView.Resources>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="ID"          Width="40"  DisplayMemberBinding="{Binding Id}"/>
                                    <GridViewColumn Header="Title"       Width="200" DisplayMemberBinding="{Binding Title}"/>
                                    <GridViewColumn Header="Description" Width="260" DisplayMemberBinding="{Binding Description}"/>
                                    <GridViewColumn Header="Reminder"    Width="120" DisplayMemberBinding="{Binding ReminderDisplay}"/>
                                    <GridViewColumn Header="Status"      Width="90"  DisplayMemberBinding="{Binding StatusText}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Mark Complete" Click="MarkComplete_Click"
                                    Margin="0,0,10,0" Padding="14,7" FontSize="12"
                                    Background="#1A4A2A" Foreground="#00FF88"
                                    BorderBrush="#00AA44" Cursor="Hand"/>
                            <Button Content="Delete Task" Click="DeleteTask_Click"
                                    Padding="14,7" FontSize="12"
                                    Background="#3A1A1A" Foreground="#FF6B6B"
                                    BorderBrush="#AA2222" Cursor="Hand"/>
                            <Button Content="Refresh" Click="RefreshTasks_Click"
                                    Margin="10,0,0,0" Padding="14,7" FontSize="12"
                                    Background="#141D35" Foreground="#8BA8C4"
                                    BorderBrush="#1A3A5C" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- QUIZ PANEL                                                   -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <Grid x:Name="PanelQuiz" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Quiz Header -->
                <Border Grid.Row="0" Background="#0F1628"
                        BorderBrush="#1A3A5C" BorderThickness="0,0,0,1"
                        Padding="20,14">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Cybersecurity Quiz" Foreground="#E8F4F8"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="QuizProgressLabel"
                                       Text="Test your cybersecurity knowledge"
                                       Foreground="#8BA8C4" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Orientation="Horizontal">
                            <Border Padding="12,6" CornerRadius="6"
                                    Background="#141D35" BorderBrush="#1A3A5C" BorderThickness="1"
                                    Margin="0,0,10,0">
                                <TextBlock x:Name="QuizScoreLabel" Text="Score: 0"
                                           Foreground="#00D4FF" FontSize="13" FontWeight="Bold"/>
                            </Border>
                            <Button Content="Start Quiz" x:Name="StartQuizButton"
                                    Click="StartQuiz_Click"
                                    Padding="16,7" FontSize="12"
                                    Foreground="#0A0E1A" BorderThickness="0" Cursor="Hand">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00D4FF" Offset="0"/>
                                        <GradientStop Color="#0088AA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Quiz Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
                    <StackPanel x:Name="QuizContentPanel" MaxWidth="680" HorizontalAlignment="Left">

                        <!-- Start Screen -->
                        <StackPanel x:Name="QuizStartScreen">
                            <TextBlock Text="Welcome to the Cybersecurity Quiz"
                                       Foreground="#E8F4F8" FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,12"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#8BA8C4" FontSize="12" LineHeight="20">
                                This quiz contains 12 questions covering key cybersecurity topics including
                                phishing, passwords, malware, 2FA, safe browsing and more.
                                Questions are randomised each time. Click Start Quiz to begin.
                            </TextBlock>
                        </StackPanel>

                        <!-- Question Screen -->
                        <StackPanel x:Name="QuizQuestionScreen" Visibility="Collapsed">
                            <Border Background="#141D35" BorderBrush="#1A3A5C"
                                    BorderThickness="1" CornerRadius="8" Padding="20,16"
                                    Margin="0,0,0,16">
                                <TextBlock x:Name="QuizQuestionText"
                                           Foreground="#E8F4F8" FontSize="14"
                                           TextWrapping="Wrap" LineHeight="22"/>
                            </Border>
                            <StackPanel x:Name="QuizOptionsPanel"/>
                        </StackPanel>

                        <!-- Feedback Screen -->
                        <Border x:Name="QuizFeedbackPanel" Visibility="Collapsed"
                                BorderThickness="1" CornerRadius="8" Padding="16,12"
                                Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock x:Name="QuizFeedbackResult"
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="QuizFeedbackExplanation"
                                           Foreground="#8BA8C4" FontSize="12"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- Final Screen -->
                        <StackPanel x:Name="QuizFinalScreen" Visibility="Collapsed">
                            <Border Background="#141D35" BorderBrush="#1A3A5C"
                                    BorderThickness="1" CornerRadius="8" Padding="24,20">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Quiz Complete"
                                               Foreground="#00D4FF" FontSize="18"
                                               FontWeight="Bold" TextAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="QuizFinalScore"
                                               Foreground="#E8F4F8" FontSize="32"
                                               FontWeight="Bold" TextAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="QuizFinalFeedback"
                                               Foreground="#8BA8C4" FontSize="13"
                                               TextAlignment="Center" TextWrapping="Wrap"
                                               Margin="0,0,0,20"/>
                                    <Button Content="Play Again" Click="StartQuiz_Click"
                                            HorizontalAlignment="Center"
                                            Padding="24,9" FontSize="13"
                                            Foreground="#0A0E1A" BorderThickness="0" Cursor="Hand">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#00D4FF" Offset="0"/>
                                                <GradientStop Color="#0088AA" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Button.Background>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Next Question Button -->
                <Border Grid.Row="2" Background="#0F1628"
                        BorderBrush="#1A3A5C" BorderThickness="0,1,0,0"
                        Padding="20,10">
                    <Button x:Name="NextQuestionButton" Content="Next Question"
                            Click="NextQuestion_Click" Visibility="Collapsed"
                            HorizontalAlignment="Right"
                            Padding="20,8" FontSize="12"
                            Foreground="#0A0E1A" BorderThickness="0" Cursor="Hand">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00D4FF" Offset="0"/>
                                <GradientStop Color="#0088AA" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- ACTIVITY LOG PANEL                                          -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <Grid x:Name="PanelActivity" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0F1628"
                        BorderBrush="#1A3A5C" BorderThickness="0,0,0,1"
                        Padding="20,14">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Activity Log" Foreground="#E8F4F8"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="ActivityCountLabel"
                                       Text="No actions recorded yet"
                                       Foreground="#8BA8C4" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button DockPanel.Dock="Right" Content="Clear Log"
                                Click="ClearLog_Click" HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Padding="14,7" FontSize="12"
                                Background="#3A1A1A" Foreground="#FF6B6B"
                                BorderBrush="#AA2222" Cursor="Hand"/>
                    </DockPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,14">
                    <StackPanel>
                        <TextBlock Text="Showing last 10 actions. Use Show More to view full history."
                                   Foreground="#3A5A7A" FontSize="10" Margin="0,0,0,10"/>
                        <ListView x:Name="ActivityListView"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#E8F4F8"
                                  FontSize="12">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Time / Date" Width="160" DisplayMemberBinding="{Binding Timestamp, StringFormat='HH:mm  dd MMM yyyy'}"/>
                                    <GridViewColumn Header="Action"      Width="520" DisplayMemberBinding="{Binding Description}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#0F1628"
                        BorderBrush="#1A3A5C" BorderThickness="0,1,0,0"
                        Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Show More" Click="ShowMoreLog_Click"
                                Padding="14,7" FontSize="12"
                                Background="#141D35" Foreground="#8BA8C4"
                                BorderBrush="#1A3A5C" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button Content="Refresh" Click="RefreshLog_Click"
                                Padding="14,7" FontSize="12"
                                Background="#141D35" Foreground="#8BA8C4"
                                BorderBrush="#1A3A5C" Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </Grid>

        </DockPanel>
    </Grid>
</Window>
